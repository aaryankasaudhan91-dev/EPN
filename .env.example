# ─── EPN Environment Configuration ───────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=epn_db
DB_USER=epn_user
DB_PASSWORD=epn_password

# ─── Authentication ───────────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random secret in production!
# Generate with: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# ─── OpenAI (optional - uses mock fallback if not set) ────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000/api

# ─── AI Configuration ─────────────────────────────────────────────────────────
# Maximum AI content generations per student per day (circuit breaker)
DAILY_CONTENT_LIMIT=10

# ─── Docker Ports (optional overrides) ────────────────────────────────────────
BACKEND_PORT=5000
FRONTEND_PORT=3000
